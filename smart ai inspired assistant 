#include <iostream>
#include <fstream>
#include <string>
#include <windows.h>

using namespace std;

// GLOBAL DATA
int totalWater = 0;
int totalSleep = 0;

// ⭐ LOADING EFFECT
void loading() {

    cout << "\n⏳ Loading";

    for(int i = 0; i < 5; i++) {
        Sleep(300);
        cout << "⭐";
    }

    cout << "\n";
}

// 🔐 REGISTER
void registerUser() {

    string u, p;

    cout << "\n📝 REGISTER\n";

    cout << "👤 Username: ";
    cin >> u;

    cout << "🔑 Password: ";
    cin >> p;

    ofstream file("users.txt", ios::app);
    file << u << " " << p << endl;

    file.close();

    cout << "✅ Registered Successfully!\n";
}

// 🔐 LOGIN
bool loginUser() {

    string u, p, su, sp;

    cout << "\n🔐 LOGIN\n";

    cout << "👤 Username: ";
    cin >> u;

    cout << "🔑 Password: ";
    cin >> p;

    ifstream file("users.txt");

    while(file >> su >> sp) {

        if(u == su && p == sp) {
            file.close();
            return true;
        }
    }

    file.close();
    return false;
}

// 💧 WATER TRACKER
void waterTracker() {

    int w;

    cout << "\n💧 WATER TRACKER\n";

    cout << "🥤 Glasses of water: ";
    cin >> w;

    totalWater = w;

    if(w >= 8)
        cout << "👍 Good hydration!\n";
    else
        cout << "⚠ Drink more water!\n";
}

// 😴 SLEEP TRACKER
void sleepTracker() {

    int s;

    cout << "\n😴 SLEEP TRACKER\n";

    cout << "🛌 Sleep hours: ";
    cin >> s;

    totalSleep = s;

    if(s >= 7)
        cout << "👍 Healthy sleep!\n";
    else
        cout << "⚠ Need more sleep!\n";
}

// 💊 MEDICINE REMINDER
